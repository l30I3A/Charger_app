<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Внешний слой для обводки и отступа -->
    <item>
        <shape>
            <solid android:color="@color/background_gray"/>
        </shape>
    </item>
    <!-- Внутренний слой для основной заливки с внутренним отступом -->
    <item>
        <shape>
            <solid android:color="@color/background_light_gray"/>
            <corners android:radius="30dp"/>
        </shape>
    </item>
</layer-list>

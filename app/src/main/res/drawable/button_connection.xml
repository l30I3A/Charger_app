<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Состояние нажатия -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <stroke
                android:width="3.4dp"
                android:color="@color/black" />
            <solid android:color="@color/progress_blue_2" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- Состояние по умолчанию -->
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="3.4dp"
                android:color="@color/black" />
            <gradient
                android:angle="270"
                android:startColor="@color/progress_blue_2"
                android:endColor="@color/progress_blue" />
            <corners android:radius="12dp" />
        </shape>
    </item>

</selector>
